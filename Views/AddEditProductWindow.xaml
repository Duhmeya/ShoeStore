<Window x:Class="ShoeStore.Views.AddEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoeStore.Views"
        mc:Ignorable="d"
        Title="редактирование товара" Height="680" Width="520"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TbTitle" 
                   Text=" редактирование товара" 
                   FontSize="20" 
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Артикул -->
                <TextBlock Text="Артикул:" FontWeight="Bold" Margin="0,5,0,2"/>
                <TextBox x:Name="TbArticle" Height="28" Margin="0,0,0,10"/>

                <!-- Наименование -->
                <TextBlock Text="Наименование:" FontWeight="Bold" Margin="0,5,0,2"/>
                <TextBox x:Name="TbName" Height="28" Margin="0,0,0,10"/>

                <!-- Категория (ComboBox) -->
                <TextBlock Text="Категория:" FontWeight="Bold" Margin="0,5,0,2"/>
                <ComboBox x:Name="CmbCategory" Height="28" Margin="0,0,0,10"
                          DisplayMemberPath="Name"/>

                <!-- Описание -->
                <TextBlock Text="Описание:" FontWeight="Bold" Margin="0,5,0,2"/>
                <TextBox x:Name="TbDescription" Height="70" 
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Производитель:" FontWeight="Bold" Margin="0,5,0,2"/>
                <ComboBox x:Name="CmbManufacturer" Height="28" Margin="0,0,0,10"
                          DisplayMemberPath="Name"/>

                <!-- Поставщик -->
                <TextBlock Text="Поставщик:" FontWeight="Bold" Margin="0,5,0,2"/>
                <ComboBox x:Name="CmbSupplier" Height="28" Margin="0,0,0,10"
                          DisplayMemberPath="Name"/>

                <!-- Цена + Ед. измерения (горизонтально) -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Цена:" FontWeight="Bold"/>
                        <TextBox x:Name="TbPrice" Height="28"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Ед. измерения:" FontWeight="Bold"/>
                        <TextBox x:Name="TbUnit" Height="28" Text="шт."/>
                    </StackPanel>
                </Grid>

                <!-- Кол-во + Скидка (горизонтально) -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Кол-во на складе:" FontWeight="Bold"/>
                        <TextBox x:Name="TbQuantity" Height="28"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Скидка (%):" FontWeight="Bold"/>
                        <TextBox x:Name="TbDiscount" Height="28" Text="0"/>
                    </StackPanel>
                </Grid>
                <!-- Кнопки действий -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <Button Content="Сохранить" 
                            Style="{StaticResource AccentButton}"
                            Width="120" Height="35"

                            Click="BtnSave_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
