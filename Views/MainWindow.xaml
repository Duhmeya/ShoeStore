<Window x:Class="ShoeStore.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoeStore.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="750" Width="1250"
        MinHeight="400" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#7FFF00" Padding="8">
            <Grid>
                <Image Source="/Resources/logo.jpg" Width="120" Height="45" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5 0 15 0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="TbUserName" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" Margin="0 0 20 0" Text="Гость"/>
                    <Button x:Name="BtnExit" Content="выход" Height="32" Margin="10 0 0 0" Click="BtnExit_Click"/>
                    </StackPanel>
            </Grid>
        </Border>
        
        <Border Grid.Row="1" x:Name="FilterPanel" Background="#f5f5f5" Padding="10" BorderBrush="#DDD" BorderThickness="0 0 0 1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Поставщик:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 8 0"/>
                <ComboBox x:Name="CmbSupplier" Width="180" Height="28"/>
                <Rectangle Width="1" Fill="#CCC" Margin="25 0 25 0"/>
                <TextBlock Text="сортировка:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 8 0"/>
                <ComboBox x:Name="CmbSoft" Width="200" Height="28"/>
            </StackPanel>
        </Border>

        <ItemsControl x:Name="ItemsProducts" Grid.Row="2" Margin="15"/>
        <Border Grid.Row="3" Background="#7FFF00" Padding="8 5">
            <TextBlock x:Name="TbStatus" Text="Готово"/>
        </Border>
    </Grid>
</Window>
